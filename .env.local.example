# =====================================================
# Exemplo de configuração para ambiente de desenvolvimento
# =====================================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.local
# 2. Preencha com os valores do seu projeto FlagHubDB-Dev
# 3. NUNCA commite o arquivo .env.local (já está no .gitignore)
#
# =====================================================

# =====================================================
# SUPABASE - FlagHubDB-Dev
# =====================================================
# Obtenha em: Supabase Dashboard → Settings → API

# URL do projeto (obrigatório)
VITE_SUPABASE_URL=https://[seu-project-ref].supabase.co

# Chave pública anônima (obrigatório)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de serviço (opcional - apenas para scripts administrativos)
# ⚠️ NUNCA exponha esta chave no frontend!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =====================================================
# VDESK API (Opcional - para testes)
# =====================================================
# Configure se quiser testar integrações com VDesk

VITE_VDESK_API_URL=https://api-dev.vdesk.com
VITE_VDESK_API_TOKEN=seu_token_aqui

# =====================================================
# AMBIENTE
# =====================================================

# Modo de desenvolvimento
VITE_ENV=development

# Habilitar logs detalhados
VITE_DEBUG=true

# =====================================================
# DATABASE (Opcional - para scripts CLI)
# =====================================================
# Connection string direto ao PostgreSQL

DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# =====================================================
# NOTAS
# =====================================================
#
# Para obter suas credenciais:
# 1. Acesse: https://supabase.com/dashboard/project/[project-ref]
# 2. Settings → API
# 3. Copie URL e Keys
#
# Para trocar entre ambientes:
# - Dev: use .env.local (este arquivo)
# - Prod: use .env.production (não commitar!)
#
# =====================================================
