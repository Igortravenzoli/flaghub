/**
 * Hook para gerenciar correlação entre Tickets e OS
 * 
 * Fornece funcionalidades de:
 * - Correlação individual e em lote
 * - Métricas de correlação
 * - Validação de OS
 * - Relatórios de inconsistências
 */

import { useState, useCallback } from 'react';
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
import { useAuth } from './useAuth';
import { 
  correlationService,
  type CorrelationResult,
  type CorrelationMetrics,
  type OSValidationPayload 
} from '@/services/ticketOSCorrelation';
import { toast } from '@/hooks/use-toast';

export function useTicketOSCorrelation() {
  const { networkId } = useAuth();
  const queryClient = useQueryClient();
  const [isCorrelating, setIsCorrelating] = useState(false);

  // Query para métricas de correlação
  const {
    data: metrics,
    isLoading: metricsLoading,
    refetch: refetchMetrics,
  } = useQuery({
    queryKey: ['correlation-metrics', networkId],
    queryFn: async () => {
      if (!networkId) return null;
      return await correlationService.getCorrelationMetrics(networkId);
    },
    enabled: !!networkId,
    refetchInterval: 120000, // 2 minutos
  });

  // Query para tickets que precisam de correlação
  const {
    data: ticketsNeedingCorrelation,
    isLoading: ticketsNeedingCorrelationLoading,
    refetch: refetchTicketsNeedingCorrelation,
  } = useQuery({
    queryKey: ['tickets-needing-correlation', networkId],
    queryFn: async () => {
      if (!networkId) return [];
      return await correlationService.getTicketsNeedingCorrelation(networkId);
    },
    enabled: !!networkId,
  });

  // Query para relatório de inconsistências
  const {
    data: inconsistencyReport,
    isLoading: inconsistencyReportLoading,
    refetch: refetchInconsistencyReport,
  } = useQuery({
    queryKey: ['inconsistency-report', networkId],
    queryFn: async () => {
      if (!networkId) return [];
      return await correlationService.generateInconsistencyReport(networkId);
    },
    enabled: !!networkId,
  });

  // Mutation para correlacionar um ticket
  const correlateSingleMutation = useMutation({
    mutationFn: async (ticketExternalId: string) => {
      return await correlationService.correlateTicket(ticketExternalId);
    },
    onSuccess: (result: CorrelationResult) => {
      queryClient.invalidateQueries({ queryKey: ['correlation-metrics', networkId] });
      queryClient.invalidateQueries({ queryKey: ['tickets', networkId] });
      queryClient.invalidateQueries({ queryKey: ['dashboard-summary', networkId] });
      
      if (result.issues.length === 0) {
        toast({
          title: 'Correlação concluída',
          description: `Ticket ${result.ticketId} correlacionado com sucesso (score: ${result.correlationScore}%)`,
        });
      } else {
        const criticalIssues = result.issues.filter(i => i.severity === 'critical').length;
        toast({
          title: criticalIssues > 0 ? 'Correlação com problemas' : 'Correlação parcial',
          description: `${result.issues.length} problema(s) encontrado(s)`,
          variant: criticalIssues > 0 ? 'destructive' : 'default',
        });
      }
    },
    onError: (error) => {
      toast({
        title: 'Erro na correlação',
        description: `${error}`,
        variant: 'destructive',
      });
    },
  });

  // Mutation para correlacionar múltiplos tickets
  const correlateBatchMutation = useMutation({
    mutationFn: async (ticketIds: string[]) => {
      return await correlationService.correlateTickets(ticketIds);
    },
    onSuccess: (results: CorrelationResult[]) => {
      queryClient.invalidateQueries({ queryKey: ['correlation-metrics', networkId] });
      queryClient.invalidateQueries({ queryKey: ['tickets', networkId] });
      queryClient.invalidateQueries({ queryKey: ['dashboard-summary', networkId] });
      queryClient.invalidateQueries({ queryKey: ['tickets-needing-correlation', networkId] });
      
      const totalIssues = results.reduce((sum, r) => sum + r.issues.length, 0);
      const criticalIssues = results.reduce(
        (sum, r) => sum + r.issues.filter(i => i.severity === 'critical').length, 
        0
      );
      
      toast({
        title: 'Correlação em lote concluída',
        description: `${results.length} tickets processados. ${totalIssues} problema(s) encontrado(s) (${criticalIssues} crítico(s))`,
        variant: criticalIssues > 0 ? 'destructive' : 'default',
      });
    },
    onError: (error) => {
      toast({
        title: 'Erro na correlação em lote',
        description: `${error}`,
        variant: 'destructive',
      });
    },
  });

  // Mutation para validar OS
  const validateOSMutation = useMutation({
    mutationFn: async ({ 
      ticketExternalId, 
      osValidation 
    }: { 
      ticketExternalId: string; 
      osValidation: OSValidationPayload 
    }) => {
      return await correlationService.updateOSValidation(ticketExternalId, osValidation);
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['correlation-metrics', networkId] });
      queryClient.invalidateQueries({ queryKey: ['tickets', networkId] });
      queryClient.invalidateQueries({ queryKey: ['dashboard-summary', networkId] });
      
      toast({
        title: 'OS validada',
        description: 'Validação registrada com sucesso',
      });
    },
    onError: (error) => {
      toast({
        title: 'Erro ao validar OS',
        description: `${error}`,
        variant: 'destructive',
      });
    },
  });

  // Mutation para marcar OS como não encontrada
  const markOSNotFoundMutation = useMutation({
    mutationFn: async (ticketExternalId: string) => {
      return await correlationService.markOSNotFound(ticketExternalId);
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['correlation-metrics', networkId] });
      queryClient.invalidateQueries({ queryKey: ['tickets', networkId] });
      queryClient.invalidateQueries({ queryKey: ['dashboard-summary', networkId] });
      
      toast({
        title: 'OS marcada como não encontrada',
        description: 'Status atualizado com sucesso',
        variant: 'destructive',
      });
    },
    onError: (error) => {
      toast({
        title: 'Erro ao atualizar status',
        description: `${error}`,
        variant: 'destructive',
      });
    },
  });

  // Função para correlacionar todos os tickets pendentes
  const correlateAllPending = useCallback(async () => {
    if (!ticketsNeedingCorrelation || ticketsNeedingCorrelation.length === 0) {
      toast({
        title: 'Nenhum ticket pendente',
        description: 'Não há tickets aguardando correlação',
      });
      return;
    }

    setIsCorrelating(true);
    try {
      await correlateBatchMutation.mutateAsync(ticketsNeedingCorrelation);
    } finally {
      setIsCorrelating(false);
    }
  }, [ticketsNeedingCorrelation, correlateBatchMutation]);

  // Função para forçar refresh de todas as queries
  const refreshAll = useCallback(() => {
    refetchMetrics();
    refetchTicketsNeedingCorrelation();
    refetchInconsistencyReport();
    queryClient.invalidateQueries({ queryKey: ['tickets', networkId] });
    queryClient.invalidateQueries({ queryKey: ['dashboard-summary', networkId] });
  }, [
    refetchMetrics, 
    refetchTicketsNeedingCorrelation, 
    refetchInconsistencyReport, 
    queryClient, 
    networkId
  ]);

  return {
    // Estado
    metrics,
    metricsLoading,
    ticketsNeedingCorrelation,
    ticketsNeedingCorrelationLoading,
    inconsistencyReport,
    inconsistencyReportLoading,
    isCorrelating,

    // Ações
    correlateTicket: correlateSingleMutation.mutate,
    correlateTicketAsync: correlateSingleMutation.mutateAsync,
    correlateTickets: correlateBatchMutation.mutate,
    correlateTicketsAsync: correlateBatchMutation.mutateAsync,
    correlateAllPending,
    validateOS: validateOSMutation.mutate,
    validateOSAsync: validateOSMutation.mutateAsync,
    markOSNotFound: markOSNotFoundMutation.mutate,
    markOSNotFoundAsync: markOSNotFoundMutation.mutateAsync,
    refreshAll,

    // Estados de loading
    isCorrelatingTicket: correlateSingleMutation.isPending,
    isCorrelatingBatch: correlateBatchMutation.isPending,
    isValidatingOS: validateOSMutation.isPending,
    isMarkingNotFound: markOSNotFoundMutation.isPending,
  };
}
